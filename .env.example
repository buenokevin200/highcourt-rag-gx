# Variables de entorno para HighCourt RAG
# Copia este archivo a .env y ajusta los valores

# --- Backend ---
SECRET_KEY=change-this-to-a-random-secret-key-in-production
DEBUG=false
DATABASE_URL=sqlite:///./data/hcourt.db

# --- ChromaDB ---
CHROMA_HOST=chromadb
CHROMA_PORT=8001

# --- Frontend ---
# No se requieren variables de entorno para el frontend
